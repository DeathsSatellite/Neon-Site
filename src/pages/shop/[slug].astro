---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PlaceholderArt from '../../components/PlaceholderArt.astro';
import ProductCard from '../../components/ProductCard.astro';
import { products, categoryLabels } from '../../data/products';
import { site } from '../../data/site';

export function getStaticPaths() {
  return products.map((p) => ({ params: { slug: p.slug }, props: { product: p } }));
}

const { product } = Astro.props;
const related = products.filter((p) => p.slug !== product.slug && !p.soldOut).slice(0, 4);
const savings = product.compareAt ? product.compareAt - product.price : 0;
---

<BaseLayout title={product.name} description={product.blurb}>
  <div class="container container--wide pdp">
    <nav class="breadcrumb hud" aria-label="Breadcrumb">
      <a href="/shop">Shop</a> <span aria-hidden="true">/</span>
      <a href={`/shop?category=${product.category}`}>{categoryLabels[product.category]}</a>
      <span aria-hidden="true">/</span> <span class="breadcrumb__current">{product.name}</span>
    </nav>

    <div class="pdp__grid">
      <!-- Media -->
      <div class="pdp__media">
        <div class="pdp__frame panel panel--hard scanlines">
          {product.soldOut && <span class="badge badge--sold">Sold Out</span>}
          {!product.soldOut && product.badge && <span class="badge">{product.badge}</span>}
          <PlaceholderArt seed={product.seed} ratio="1 / 1" label="PLACEHOLDER // SWAP PHOTO" />
        </div>
        <div class="pdp__thumbs">
          {[0, 1, 2].map((i) => (
            <div class="pdp__thumb panel">
              <PlaceholderArt seed={product.seed + i} ratio="1 / 1" />
            </div>
          ))}
        </div>
      </div>

      <!-- Info -->
      <div class="pdp__info">
        <p class="eyebrow">{categoryLabels[product.category]}</p>
        <h1 class="display pdp__title">{product.name}</h1>

        <div class="pdp__price">
          <span class="display pdp__price-now">{site.currencySymbol}{product.price}</span>
          {product.compareAt && (
            <>
              <span class="pdp__price-was">{site.currencySymbol}{product.compareAt}</span>
              <span class="tape">Save {site.currencySymbol}{savings}</span>
            </>
          )}
        </div>

        <p class="lede pdp__desc">{product.description}</p>

        <form class="pdp__form" data-pdp-form>
          {product.sizes.length > 0 && (
            <fieldset class="pdp__sizes">
              <legend class="hud">Size <span class="pdp__req" data-size-req hidden>· pick one</span></legend>
              <div class="size-row" role="radiogroup" aria-label="Size">
                {product.sizes.map((s) => (
                  <label class="size-opt">
                    <input type="radio" name="size" value={s} />
                    <span>{s}</span>
                  </label>
                ))}
              </div>
            </fieldset>
          )}

          <div class="pdp__qty">
            <span class="hud">Qty</span>
            <div class="qty-stepper">
              <button type="button" data-qty-dec aria-label="Decrease quantity">−</button>
              <span data-qty-val aria-live="polite">1</span>
              <button type="button" data-qty-inc aria-label="Increase quantity">+</button>
            </div>
          </div>

          {product.soldOut ? (
            <button type="button" class="btn btn--lg btn--ghost pdp__add" disabled>Sold Out</button>
          ) : (
            <button
              type="submit"
              class="btn btn--lg pdp__add"
              data-slug={product.slug}
              data-name={product.name}
              data-price={product.price}
              data-seed={product.seed}
            >
              Add to Cart · {site.currencySymbol}{product.price}
            </button>
          )}
          <p class="pdp__ship hud">◈ Free local pickup in {site.areaCode} · Ships nationwide</p>
        </form>

        <ul role="list" class="pdp__trust">
          <li class="hud">Made in Jax</li>
          <li class="hud">Small-batch</li>
          <li class="hud">Signed by the artist</li>
        </ul>
      </div>
    </div>

    <!-- Related -->
    <section class="section pdp__related" aria-labelledby="rel-title">
      <h2 id="rel-title" class="display sec-title">More from the Drop</h2>
      <div class="grid rel-grid">
        {related.map((p) => <ProductCard product={p} />)}
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .pdp {
    padding-top: var(--sp-5);
  }
  .breadcrumb {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    color: var(--fog-dim);
    margin-bottom: var(--sp-5);
  }
  .breadcrumb a:hover {
    color: var(--accent-2);
  }
  .breadcrumb__current {
    color: var(--fog);
  }
  .pdp__grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    gap: var(--sp-8);
    align-items: start;
  }
  .pdp__frame {
    position: relative;
    overflow: hidden;
  }
  .pdp__thumbs {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--sp-3);
    margin-top: var(--sp-3);
  }
  .pdp__thumb {
    overflow: hidden;
    cursor: pointer;
  }
  .pdp__title {
    font-size: var(--fs-2xl);
    margin: var(--sp-2) 0 var(--sp-4);
  }
  .pdp__price {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    margin-bottom: var(--sp-4);
    flex-wrap: wrap;
  }
  .pdp__price-now {
    font-size: 2.4rem;
    color: var(--accent-3);
  }
  .pdp__price-was {
    color: var(--fog-dim);
    text-decoration: line-through;
    font-size: 1.2rem;
  }
  .pdp__desc {
    margin-bottom: var(--sp-5);
  }
  .pdp__form {
    display: grid;
    gap: var(--sp-5);
    padding: var(--sp-5);
    background: var(--concrete);
    border: 2px solid var(--line-strong);
    border-radius: var(--r-2);
  }
  .pdp__sizes {
    border: none;
    padding: 0;
    margin: 0;
  }
  .pdp__sizes legend {
    color: var(--accent-2);
    margin-bottom: var(--sp-3);
  }
  .pdp__req {
    color: var(--magenta);
  }
  .size-row {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-2);
  }
  .size-opt {
    cursor: pointer;
  }
  .size-opt input {
    position: absolute;
    opacity: 0;
    width: 1px;
    height: 1px;
  }
  .size-opt span {
    display: grid;
    place-items: center;
    min-width: 48px;
    min-height: 48px;
    padding: 0 0.5rem;
    border: 2px solid var(--line-strong);
    border-radius: var(--r-1);
    font-weight: 700;
    transition: all 0.14s ease;
  }
  .size-opt input:hover + span {
    border-color: var(--accent-2);
  }
  .size-opt input:checked + span {
    background: var(--accent);
    color: var(--on-accent);
    border-color: var(--ink);
  }
  .size-opt input:focus-visible + span {
    outline: 3px solid var(--accent-2);
    outline-offset: 2px;
  }
  .pdp__qty {
    display: flex;
    align-items: center;
    gap: var(--sp-4);
  }
  .pdp__qty .hud {
    color: var(--accent-2);
  }
  .qty-stepper {
    display: inline-flex;
    align-items: center;
    gap: 0.75rem;
    border: 2px solid var(--line-strong);
    border-radius: var(--r-1);
    padding: 0.25rem;
  }
  .qty-stepper button {
    width: 40px;
    height: 40px;
    display: grid;
    place-items: center;
    color: var(--chalk);
    font-size: 1.2rem;
  }
  .qty-stepper button:hover {
    color: var(--accent-2);
  }
  .qty-stepper span {
    min-width: 2ch;
    text-align: center;
    font-variant-numeric: tabular-nums;
    font-weight: 700;
  }
  .pdp__add {
    width: 100%;
  }
  .pdp__ship {
    color: var(--fog-dim);
    text-align: center;
  }
  .pdp__trust {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-4);
    margin-top: var(--sp-5);
    color: var(--fog-dim);
  }
  .pdp__trust li {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }
  .pdp__trust li::before {
    content: '✓';
    color: var(--lime);
  }
  .sec-title {
    font-size: var(--fs-xl);
    margin-bottom: var(--sp-5);
  }
  .rel-grid {
    grid-template-columns: repeat(4, 1fr);
  }
  @media (max-width: 900px) {
    .pdp__grid {
      grid-template-columns: 1fr;
    }
    .rel-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  @media (max-width: 460px) {
    .rel-grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  import { addToCart, openCart } from '../../scripts/cart';

  const form = document.querySelector<HTMLFormElement>('[data-pdp-form]');
  const qtyVal = document.querySelector<HTMLElement>('[data-qty-val]');
  const sizeReq = document.querySelector<HTMLElement>('[data-size-req]');
  let qty = 1;

  document.querySelector('[data-qty-dec]')?.addEventListener('click', () => {
    qty = Math.max(1, qty - 1);
    if (qtyVal) qtyVal.textContent = String(qty);
  });
  document.querySelector('[data-qty-inc]')?.addEventListener('click', () => {
    qty = Math.min(99, qty + 1);
    if (qtyVal) qtyVal.textContent = String(qty);
  });

  form?.addEventListener('submit', (e) => {
    e.preventDefault();
    const btn = form.querySelector<HTMLButtonElement>('.pdp__add');
    if (!btn || btn.disabled) return;

    const hasSizes = !!form.querySelector('input[name="size"]');
    let size = '';
    if (hasSizes) {
      const checked = form.querySelector<HTMLInputElement>('input[name="size"]:checked');
      if (!checked) {
        if (sizeReq) sizeReq.hidden = false;
        form.querySelector<HTMLElement>('.size-row')?.scrollIntoView({ block: 'center', behavior: 'smooth' });
        return;
      }
      size = checked.value;
      if (sizeReq) sizeReq.hidden = true;
    }

    addToCart({
      slug: btn.dataset.slug!,
      name: btn.dataset.name!,
      price: Number(btn.dataset.price),
      seed: Number(btn.dataset.seed),
      size,
      qty,
    });
    openCart();
  });
</script>
