---
import { site } from '../data/site';
const year = new Date().getFullYear();
const shopLinks = [
  { href: '/shop', label: 'All Products' },
  { href: '/shop?category=apparel', label: 'Apparel' },
  { href: '/shop?category=prints', label: 'Prints' },
  { href: '/gallery', label: 'Gallery' },
];
const infoLinks = [
  { href: '/about', label: 'About' },
  { href: '/commissions', label: 'Commissions' },
  { href: '/cart', label: 'Cart' },
];
---

<footer class="site-footer">
  <div class="marquee marquee--cyan" aria-hidden="true">
    <div class="marquee__track">
      <span>Free local pickup · Duval County</span>
      <span>Ships nationwide</span>
      <span>Limited drops · No restocks</span>
      <span>Real spray, real city</span>
      <span>Free local pickup · Duval County</span>
      <span>Ships nationwide</span>
      <span>Limited drops · No restocks</span>
      <span>Real spray, real city</span>
    </div>
  </div>

  <div class="container container--wide footer__grid">
    <div class="footer__brand">
      <a href="/" class="brand__name display">{site.brand}</a>
      <p class="lede footer__tag">{site.tagline}</p>
      <p class="hud footer__loc">◈ {site.city} · {site.areaCode}</p>
    </div>

    <nav class="footer__col" aria-label="Shop">
      <h2 class="hud footer__h">Shop</h2>
      <ul role="list">
        {shopLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </nav>

    <nav class="footer__col" aria-label="Info">
      <h2 class="hud footer__h">Info</h2>
      <ul role="list">
        {infoLinks.map((l) => <li><a href={l.href}>{l.label}</a></li>)}
      </ul>
    </nav>

    <div class="footer__col">
      <h2 class="hud footer__h">Follow</h2>
      <ul role="list">
        {site.socials.map((s) => (
          <li><a href={s.href}>{s.label} <span class="footer__handle">{s.handle}</span></a></li>
        ))}
        <li><a href={`mailto:${site.email}`}>{site.email}</a></li>
      </ul>
    </div>
  </div>

  <div class="container container--wide footer__base">
    <p class="hud">© {year} {site.brand} · {site.legalName}</p>
    <p class="hud footer__credit">Placeholder content — swap for the real artist's work.</p>
  </div>
</footer>

<style>
  .site-footer {
    margin-top: var(--sp-12);
    border-top: 2px solid var(--line-strong);
    background: var(--concrete);
  }
  .footer__grid {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1.4fr;
    gap: var(--sp-6);
    padding-block: var(--sp-8);
  }
  .footer__brand .brand__name {
    font-size: clamp(2rem, 5vw, 3rem);
  }
  .footer__tag {
    margin-top: var(--sp-3);
    max-width: 32ch;
  }
  .footer__loc {
    margin-top: var(--sp-4);
    color: var(--accent-2);
  }
  .footer__h {
    color: var(--accent);
    margin-bottom: var(--sp-3);
  }
  .footer__col ul {
    display: grid;
    gap: 0.7rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .footer__col a {
    color: var(--fog);
    transition: color 0.15s ease;
  }
  .footer__col a:hover {
    color: var(--chalk);
  }
  .footer__handle {
    display: block;
    color: var(--fog-dim);
    font-size: 0.8rem;
  }
  .footer__base {
    display: flex;
    flex-wrap: wrap;
    gap: var(--sp-3);
    justify-content: space-between;
    padding-block: var(--sp-4);
    border-top: 2px solid var(--line);
    color: var(--fog-dim);
  }
  @media (max-width: 760px) {
    .footer__grid {
      grid-template-columns: 1fr 1fr;
    }
    .footer__brand {
      grid-column: 1 / -1;
    }
  }
</style>
