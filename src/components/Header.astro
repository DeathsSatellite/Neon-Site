---
import { site } from '../data/site';

const links = [
  { href: '/shop', label: 'Shop' },
  { href: '/gallery', label: 'Gallery' },
  { href: '/about', label: 'About' },
  { href: '/commissions', label: 'Commissions' },
];
const path = Astro.url.pathname;
const isActive = (href: string) => path === href || (href !== '/' && path.startsWith(href));
---

<header class="site-header scanlines">
  <div class="container container--wide header__inner">
    <a href="/" class="brand" aria-label={`${site.brand} home`}>
      <span class="brand__mark" aria-hidden="true">◣◥</span>
      <span class="brand__name display">{site.brand}</span>
      <span class="brand__code hud">{site.areaCode}</span>
    </a>

    <nav class="nav" aria-label="Primary">
      <ul role="list" class="nav__list">
        {links.map((l) => (
          <li>
            <a href={l.href} class:list={['nav__link hud', { 'is-active': isActive(l.href) }]}>
              {l.label}
            </a>
          </li>
        ))}
      </ul>
    </nav>

    <div class="header__actions">
      <button type="button" class="cart-btn" data-cart-open aria-label="Open cart">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <path
            d="M3 4h2l2.4 12.3a1 1 0 0 0 1 .8h8.7a1 1 0 0 0 1-.8L21 8H6"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="square"
          ></path>
          <circle cx="9" cy="21" r="1.4" fill="currentColor"></circle>
          <circle cx="18" cy="21" r="1.4" fill="currentColor"></circle>
        </svg>
        <span class="cart-btn__count hud" data-cart-count>0</span>
      </button>

      <button type="button" class="menu-btn" data-menu-toggle aria-expanded="false" aria-controls="mobile-nav" aria-label="Open menu">
        <span></span><span></span><span></span>
      </button>
    </div>
  </div>

  <!-- Mobile nav -->
  <nav id="mobile-nav" class="mobile-nav" aria-label="Mobile" data-mobile-nav hidden>
    <ul role="list">
      {links.map((l) => (
        <li>
          <a href={l.href} class:list={['display', { 'is-active': isActive(l.href) }]}>{l.label}</a>
        </li>
      ))}
    </ul>
    <div class="mobile-nav__socials">
      {site.socials.map((s) => (
        <a href={s.href} class="hud">{s.label}</a>
      ))}
    </div>
  </nav>
</header>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: rgba(13, 13, 15, 0.82);
    backdrop-filter: blur(10px);
    border-bottom: 2px solid var(--line-strong);
  }
  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--sp-4);
    height: var(--header-h);
  }
  .brand {
    display: inline-flex;
    align-items: center;
    gap: 0.55rem;
  }
  .brand__mark {
    color: var(--accent);
    letter-spacing: -3px;
    font-size: 1.1rem;
  }
  .brand__name {
    font-size: 1.55rem;
    line-height: 1;
  }
  .brand__code {
    color: var(--accent-2);
    border: 2px solid var(--accent-2);
    padding: 0.1em 0.35em;
    font-size: 0.55rem;
  }
  .nav__list {
    display: flex;
    gap: var(--sp-5);
  }
  .nav__link {
    position: relative;
    color: var(--fog);
    padding-block: 0.4rem;
    transition: color 0.15s ease;
  }
  .nav__link::after {
    content: '';
    position: absolute;
    left: 0;
    bottom: -2px;
    width: 100%;
    height: 3px;
    background: var(--accent);
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.18s ease;
  }
  .nav__link:hover,
  .nav__link.is-active {
    color: var(--chalk);
  }
  .nav__link:hover::after,
  .nav__link.is-active::after {
    transform: scaleX(1);
  }
  .header__actions {
    display: flex;
    align-items: center;
    gap: var(--sp-3);
  }
  .cart-btn {
    position: relative;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    color: var(--chalk);
    border: 2px solid var(--line-strong);
    border-radius: var(--r-1);
    transition: border-color 0.15s ease, color 0.15s ease;
  }
  .cart-btn:hover {
    border-color: var(--accent);
    color: var(--accent);
  }
  .cart-btn__count {
    position: absolute;
    top: -8px;
    right: -8px;
    min-width: 20px;
    height: 20px;
    padding: 0 4px;
    display: grid;
    place-items: center;
    font-size: 0.5rem;
    color: var(--on-accent);
    background: var(--accent);
    border: 2px solid var(--ink);
    border-radius: var(--r-pill);
    transform: scale(0);
    transition: transform 0.18s cubic-bezier(0.34, 1.56, 0.64, 1);
  }
  .cart-btn__count.has-items {
    transform: scale(1);
  }
  .menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    width: 48px;
    height: 48px;
    align-items: center;
    justify-content: center;
    border: 2px solid var(--line-strong);
    border-radius: var(--r-1);
  }
  .menu-btn span {
    width: 20px;
    height: 2px;
    background: var(--chalk);
    transition: transform 0.2s ease, opacity 0.2s ease;
  }
  .menu-btn[aria-expanded='true'] span:nth-child(1) {
    transform: translateY(7px) rotate(45deg);
  }
  .menu-btn[aria-expanded='true'] span:nth-child(2) {
    opacity: 0;
  }
  .menu-btn[aria-expanded='true'] span:nth-child(3) {
    transform: translateY(-7px) rotate(-45deg);
  }
  .mobile-nav {
    border-bottom: 2px solid var(--line-strong);
    background: var(--ink);
    padding: var(--sp-4) 1rem var(--sp-6);
  }
  .mobile-nav[hidden] {
    display: none;
  }
  .mobile-nav ul {
    display: grid;
    gap: 0.25rem;
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .mobile-nav a.display {
    display: block;
    font-size: 2rem;
    padding: 0.4rem 0;
    color: var(--fog);
  }
  .mobile-nav a.is-active {
    color: var(--accent);
  }
  .mobile-nav__socials {
    display: flex;
    flex-wrap: wrap;
    gap: 1rem;
    margin-top: var(--sp-4);
    color: var(--fog-dim);
  }

  @media (max-width: 860px) {
    .nav {
      display: none;
    }
    .menu-btn {
      display: inline-flex;
    }
  }
</style>

<script>
  // Mobile menu toggle
  const toggle = document.querySelector<HTMLButtonElement>('[data-menu-toggle]');
  const mnav = document.querySelector<HTMLElement>('[data-mobile-nav]');
  toggle?.addEventListener('click', () => {
    const open = toggle.getAttribute('aria-expanded') === 'true';
    toggle.setAttribute('aria-expanded', String(!open));
    if (mnav) mnav.hidden = open;
  });
  // Close mobile nav on navigation
  mnav?.querySelectorAll('a').forEach((a) =>
    a.addEventListener('click', () => {
      toggle?.setAttribute('aria-expanded', 'false');
      if (mnav) mnav.hidden = true;
    })
  );
</script>

<script>
  // Live cart-count badge — subscribes to the shared store
  import { cart, cartCount, openCart } from '../scripts/cart';
  const countEl = document.querySelector<HTMLElement>('[data-cart-count]');
  cart.subscribe((lines) => {
    const n = cartCount(lines);
    if (countEl) {
      countEl.textContent = String(n);
      countEl.classList.toggle('has-items', n > 0);
    }
  });
  document
    .querySelector('[data-cart-open]')
    ?.addEventListener('click', () => openCart());
</script>
